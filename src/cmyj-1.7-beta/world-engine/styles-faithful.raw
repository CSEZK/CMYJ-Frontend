/* High-fidelity pass based on the selected 1652 × 952 visual target. */
:root {
  --paper: #17150f;
  --paper-raised: #1d1912;
  --paper-deep: #0d0c09;
  --ink: #d9c8a8;
  --ink-bright: #f0dfbd;
  --muted: #b6a483;
  --faint: #766952;
  --line: rgba(186, 148, 88, 0.2);
  --line-strong: rgba(190, 151, 91, 0.38);
  --cinnabar: #aa402f;
  --cinnabar-bright: #d35a43;
  --gold: #c39250;
  --jade: #8da17f;
  --shadow: rgba(0, 0, 0, 0.76);
  font-family: 'Microsoft YaHei', 'PingFang SC', 'Noto Sans CJK SC', sans-serif;
}

html,
body,
#cwe-root {
  color: var(--ink);
  background: transparent;
}

body {
  padding: 0;
}

.cwe-panel {
  position: relative;
  display: grid;
  height: 100%;
  min-height: 0;
  grid-template-rows: 94px minmax(0, 1fr);
  overflow: hidden;
  border: 0;
  border-radius: 0;
  background-color: #17150f;
  background-image: none;
  box-shadow: 0 28px 90px var(--shadow);
  isolation: isolate;
}

.cwe-panel::before {
  position: absolute;
  z-index: 0;
  inset: 0;
  background-image: url('__LEDGER_TEXTURE__');
  background-position: center;
  background-repeat: repeat;
  background-size: 720px 720px;
  content: '';
  opacity: 0.2;
  pointer-events: none;
}

.cwe-panel::after {
  position: absolute;
  z-index: 1;
  inset: 0;
  border: 0;
  background-image: url('__FRAME_ORNAMENT__');
  background-position: center;
  background-repeat: no-repeat;
  background-size: 100% 100%;
  content: '';
  filter: sepia(0.3) saturate(0.72) brightness(0.88);
  opacity: 0.82;
  pointer-events: none;
}

.cwe-header,
.cwe-shell {
  position: relative;
  z-index: 2;
}

.cwe-header {
  display: flex;
  min-height: 94px;
  align-items: center;
  justify-content: space-between;
  gap: 30px;
  margin: 0 36px;
  padding: 0 48px 0 20px;
  border-bottom: 1px solid rgba(190, 151, 91, 0.34);
  background: rgba(13, 12, 9, 0.76);
  box-shadow: none;
  backdrop-filter: none;
}

.cwe-brand {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 17px;
}

.cwe-brand-mark {
  width: 61px;
  height: 61px;
  flex: 0 0 61px;
  border: 0;
  border-radius: 0;
  object-fit: contain;
  background: transparent;
  box-shadow: none;
}

.cwe-brand-title {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 30px;
}

.cwe-brand-title > div {
  display: flex;
  align-items: center;
  gap: 11px;
}

.cwe-brand h1 {
  margin: 0;
  color: var(--ink-bright);
  font-family: 'STKaiti', 'KaiTi', 'Noto Serif CJK SC', 'Source Han Serif SC', serif;
  font-size: clamp(31px, 2.35vw, 42px);
  font-weight: 700;
  letter-spacing: 0.12em;
  line-height: 1;
  text-shadow: 0 1px 0 #000;
  white-space: nowrap;
}

.cwe-title-seal {
  display: grid;
  width: 24px;
  height: 31px;
  place-items: center;
  border: 1px solid rgba(192, 66, 45, 0.8);
  color: #c75843;
  font-family: 'STKaiti', 'KaiTi', serif;
  font-size: 13px;
  line-height: 1;
}

.cwe-brand p {
  max-width: 310px;
  margin: 0;
  color: #c0ad89;
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 15px;
  letter-spacing: 0.08em;
  white-space: nowrap;
}

.cwe-header-actions {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 20px;
  padding-right: 16px;
}

.cwe-connection {
  display: flex;
  min-width: 0;
  max-width: 520px;
  align-items: center;
  gap: 13px;
  color: #b7a685;
  font-size: 13px;
}

.cwe-connection i,
.cwe-live i {
  width: 9px;
  height: 9px;
  flex: 0 0 9px;
  border-radius: 50%;
  background: var(--jade);
  box-shadow: 0 0 0 3px rgba(141, 161, 127, 0.1);
}

.cwe-connection span,
.cwe-connection b {
  overflow: hidden;
  color: inherit;
  font-weight: 400;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-connection b {
  max-width: 240px;
  padding-left: 16px;
  border-left: 1px solid var(--line);
}

.cwe-live {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--muted);
  font-size: 13px;
  white-space: nowrap;
}

.cwe-header-actions > button,
.cwe-drawer-head > button {
  min-height: 34px;
  border: 0;
  border-bottom: 1px solid transparent;
  padding: 6px 3px;
  color: #aa9877;
  background: transparent;
  cursor: pointer;
  font-size: 13px;
  letter-spacing: 0.08em;
}

.cwe-header-actions > button:hover,
.cwe-drawer-head > button:hover {
  border-bottom-color: var(--cinnabar-bright);
  color: var(--ink-bright);
}

.cwe-shell {
  display: grid;
  min-height: 0;
  grid-template-rows: minmax(0, 1fr) 97px;
}

.cwe-content {
  display: grid;
  min-width: 0;
  min-height: 0;
  grid-template-rows: auto minmax(0, 1fr);
  overflow: hidden;
  padding: 0 36px;
}

.cwe-overview-lead {
  display: grid;
  min-height: 194px;
  align-items: center;
  gap: 54px;
  grid-template-columns: minmax(340px, 420px) minmax(0, 1fr);
  padding: 26px 270px 25px 35px;
  border-bottom: 1px solid rgba(190, 151, 91, 0.3);
}

.cwe-brief-kicker {
  display: flex;
  align-items: center;
  gap: 18px;
  color: var(--gold);
  font-size: 14px;
  letter-spacing: 0.12em;
}

.cwe-brief-kicker span:first-child {
  min-width: 104px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--cinnabar);
  color: var(--ink-bright);
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 17px;
  font-weight: 700;
}

.cwe-world-brief h2 {
  max-width: 560px;
  margin: 13px 0 9px;
  color: var(--ink-bright);
  font-family: 'STSong', 'Songti SC', 'Noto Serif CJK SC', serif;
  font-size: clamp(24px, 2vw, 31px);
  font-weight: 700;
  letter-spacing: 0.03em;
  line-height: 1.35;
}

.cwe-world-brief > p {
  margin: 0;
  color: #ad9b7a;
  font-size: 14px;
  line-height: 1.65;
}

.cwe-overview-status {
  display: grid;
  align-content: center;
  gap: 25px;
}

.cwe-statline {
  display: grid;
  align-items: center;
  gap: 22px 38px;
  grid-template-columns: repeat(4, minmax(112px, auto));
}

.cwe-statline span {
  display: flex;
  align-items: center;
  gap: 11px;
  color: #b8a889;
  font-size: 15px;
  white-space: nowrap;
}

.cwe-statline i {
  width: 9px;
  height: 9px;
  flex: 0 0 9px;
  border-radius: 50%;
  background: #8f8268;
  box-shadow: 0 0 0 3px rgba(143, 130, 104, 0.08);
}

.cwe-statline i.danger {
  background: var(--cinnabar-bright);
  box-shadow: 0 0 9px rgba(211, 90, 67, 0.55);
}

.cwe-statline i.busy {
  background: #d28b36;
}

.cwe-statline i.safe {
  background: var(--jade);
}

.cwe-statline b {
  min-width: 1.2em;
  color: var(--ink-bright);
  font-size: 17px;
  font-weight: 500;
  text-align: right;
}

.cwe-duty-strip {
  display: flex;
  align-items: center;
  gap: 30px;
  padding-top: 17px;
  border-top: 1px solid var(--line);
  color: #8f8065;
  font-size: 13px;
}

.cwe-duty-strip b {
  margin-left: 8px;
  color: var(--muted);
  font-weight: 500;
}

.cwe-notice {
  position: absolute;
  z-index: 20;
  top: 104px;
  right: 64px;
  max-width: 420px;
  margin: 0;
  border: 1px solid var(--line-strong);
  padding: 10px 14px;
  color: var(--muted);
  background: rgba(17, 14, 10, 0.96);
  font-size: 12px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.38);
}

.cwe-ledger-layout {
  display: grid;
  min-height: 0;
  align-items: stretch;
  grid-template-columns: minmax(0, 1fr) 365px;
  margin: 0;
  padding-left: 32px;
  border: 0;
  overflow: hidden;
}

.cwe-ledger-main {
  display: grid;
  min-width: 0;
  min-height: 0;
  grid-template-rows: minmax(0, 1fr);
  padding: 0 34px 0 0;
}

.cwe-ledger-head {
  position: absolute;
  width: 1px;
  height: 1px;
  overflow: hidden;
  clip: rect(0 0 0 0);
  clip-path: inset(50%);
  white-space: nowrap;
}

.cwe-event-list {
  min-height: 0;
  overflow: auto;
  scrollbar-color: rgba(195, 146, 80, 0.36) transparent;
  scrollbar-width: thin;
}

.cwe-event-row {
  position: relative;
  display: grid;
  min-width: 0;
  min-height: 124px;
  align-items: center;
  gap: 23px;
  grid-template-columns: 158px minmax(0, 1fr) minmax(285px, 0.66fr);
  padding: 20px 0;
  border-bottom: 1px solid rgba(186, 148, 88, 0.24);
}

.cwe-event-row:last-child {
  border-bottom: 0;
}

.cwe-event-row.is-empty {
  opacity: 0.66;
}

.cwe-event-when {
  position: relative;
  display: grid;
  align-content: center;
  gap: 5px;
  min-height: 84px;
  padding-left: 48px;
}

.cwe-event-when::before {
  position: absolute;
  top: -22px;
  bottom: -22px;
  left: 16px;
  width: 1px;
  background: rgba(190, 151, 91, 0.52);
  content: '';
}

.cwe-event-when i {
  position: absolute;
  z-index: 1;
  top: 5px;
  left: 7px;
  width: 19px;
  height: 19px;
  border: 2px solid #17150f;
  border-radius: 50%;
  background: var(--jade);
  box-shadow: 0 0 0 2px var(--jade);
}

.cwe-event-row.danger .cwe-event-when i {
  background: var(--cinnabar-bright);
  box-shadow: 0 0 0 2px var(--cinnabar-bright), 0 0 13px rgba(211, 90, 67, 0.4);
}

.cwe-event-row.busy .cwe-event-when i {
  background: #d18a34;
  box-shadow: 0 0 0 2px #d18a34;
}

.cwe-event-when strong {
  color: var(--cinnabar-bright);
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 17px;
  font-weight: 600;
}

.cwe-event-row.busy .cwe-event-when strong {
  color: #dca04e;
}

.cwe-event-row.safe .cwe-event-when strong {
  color: var(--gold);
}

.cwe-event-when b {
  color: #c5b18d;
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 14px;
  font-weight: 500;
}

.cwe-event-when span {
  overflow: hidden;
  color: #a59272;
  font-size: 13px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-event-story {
  min-width: 0;
}

.cwe-event-story header {
  display: flex;
  align-items: center;
  gap: 14px;
}

.cwe-event-story h4,
.cwe-event-story p {
  margin: 0;
}

.cwe-event-story h4 {
  overflow: hidden;
  color: var(--ink-bright);
  font-family: 'STSong', 'Songti SC', 'Noto Serif CJK SC', serif;
  font-size: clamp(20px, 1.5vw, 26px);
  font-weight: 700;
  letter-spacing: 0.025em;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-event-story p {
  max-width: 650px;
  margin-top: 7px;
  color: #b7a585;
  font-size: 16px;
  line-height: 1.68;
}

.cwe-event-detail {
  display: grid;
  align-content: center;
  gap: 7px;
  margin: 0;
}

.cwe-event-detail > div {
  display: grid;
  gap: 11px;
  grid-template-columns: 42px minmax(0, 1fr);
}

.cwe-event-detail dt,
.cwe-event-detail dd {
  margin: 0;
  font-size: 14px;
  line-height: 1.5;
}

.cwe-event-detail dt {
  color: var(--gold);
}

.cwe-event-detail dd {
  overflow: hidden;
  color: #b5a383;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-event-row.danger .cwe-event-detail > div:nth-child(2) dd {
  color: var(--cinnabar-bright);
}

.cwe-event-row.safe .cwe-event-detail > div:nth-child(2) dd {
  color: var(--jade);
}

.cwe-margin-notes {
  min-width: 0;
  border-left: 1px solid rgba(190, 151, 91, 0.38);
  overflow: hidden;
  scrollbar-width: none;
}

.cwe-margin-notes section {
  position: relative;
  min-height: 50%;
  padding: 27px 40px 24px 31px;
  border-bottom: 1px solid rgba(186, 148, 88, 0.25);
}

.cwe-margin-notes section::after {
  position: absolute;
  z-index: -1;
  top: 66px;
  right: 24px;
  bottom: 17px;
  left: 24px;
  border: 1px solid rgba(186, 148, 88, 0.16);
  content: '';
  pointer-events: none;
}

.cwe-margin-notes section:last-child {
  border-bottom: 0;
}

.cwe-margin-notes header,
.cwe-margin-notes footer {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

.cwe-margin-notes header {
  padding-bottom: 12px;
  border-bottom: 1px solid var(--line);
}

.cwe-margin-notes header small {
  color: var(--gold);
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 15px;
}

.cwe-margin-notes header b {
  color: var(--cinnabar-bright);
  font-size: 12px;
  font-weight: 600;
}

.cwe-margin-notes h3 {
  margin: 18px 0 9px;
  color: var(--ink-bright);
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 19px;
}

.cwe-margin-notes p {
  margin: 0;
  color: #b6a484;
  font-size: 15px;
  line-height: 1.75;
}

.cwe-hook-progress {
  display: grid;
  gap: 8px;
  margin-top: 15px;
  color: var(--muted);
  font-size: 12px;
}

.cwe-hook-progress > i {
  display: block;
  height: 7px;
  overflow: hidden;
  border: 1px solid rgba(190, 151, 91, 0.24);
  border-radius: 4px;
  background: #242019;
}

.cwe-hook-progress > i > b {
  display: block;
  height: 100%;
  border-radius: 4px;
  background: var(--cinnabar-bright);
}

.cwe-margin-notes footer {
  margin-top: 15px;
  padding-top: 11px;
  border-top: 1px solid var(--line);
  color: #7f7058;
  font-size: 11px;
}

.cwe-tag {
  display: inline-flex;
  align-items: center;
  border: 1px solid rgba(190, 151, 91, 0.36);
  border-radius: 2px;
  padding: 3px 8px;
  color: var(--muted);
  background: rgba(10, 9, 7, 0.38);
  font-size: 12px;
  line-height: 1.25;
  white-space: nowrap;
}

.cwe-command-bar {
  position: relative;
  z-index: 5;
  display: grid;
  min-height: 97px;
  align-content: center;
  justify-items: center;
  gap: 7px;
  grid-template-columns: 1fr;
  padding: 10px 44px 8px;
  border-top: 1px solid rgba(190, 151, 91, 0.4);
  background: rgba(10, 9, 7, 0.86);
  box-shadow: none;
  backdrop-filter: none;
}

.cwe-command-main {
  display: grid;
  left: 70px;
  width: min(840px, 78vw);
  height: 56px;
  gap: 12px;
  grid-template-columns: minmax(440px, 1fr) 58px 226px;
  position: relative;
}

.cwe-command-bar nav {
  display: grid;
  max-width: none;
  grid-template-columns: repeat(3, 1fr);
  border: 1px solid rgba(190, 151, 91, 0.38);
}

.cwe-command-bar nav button,
.cwe-settings-key,
.cwe-command-main > .primary {
  min-width: 0;
  border: 0;
  border-right: 1px solid var(--line);
  padding: 0 18px;
  color: #b4a17f;
  background: #12100c;
  cursor: pointer;
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 16px;
  letter-spacing: 0.08em;
}

.cwe-command-bar nav button:last-child {
  border-right: 0;
}

.cwe-command-bar nav button:hover,
.cwe-command-bar nav button.active,
.cwe-settings-key:hover,
.cwe-settings-key.active,
.cwe-rebuild-link:hover {
  color: var(--ink-bright);
  background: #242017;
}

.cwe-command-bar nav button.active {
  box-shadow: inset 0 -3px 0 var(--cinnabar);
}

.cwe-settings-key {
  border: 1px solid rgba(190, 151, 91, 0.38);
  padding: 0 8px;
  font-family: inherit;
  font-size: 13px;
  letter-spacing: 0;
  white-space: nowrap;
}

.cwe-command-main > .primary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  border: 1px solid rgba(218, 108, 84, 0.8);
  color: #f6e5c6;
  background: #963b2e;
  box-shadow: inset 0 0 0 3px rgba(235, 155, 120, 0.09);
  font-size: 19px;
}

.cwe-command-main > .primary:hover {
  border-color: #e19073;
  background: #a94636;
}

.cwe-command-main > .primary span {
  color: #e6b493;
  font-size: 28px;
  font-weight: 300;
  line-height: 1;
}

.cwe-command-main > .primary:disabled {
  cursor: wait;
  opacity: 0.56;
}

.cwe-command-bar > p {
  display: flex;
  justify-content: center;
  gap: 30px;
  grid-column: 1;
  margin: 0;
  color: #776a54;
  font-size: 11px;
}

.cwe-rebuild-link {
  border: 0;
  padding: 0;
  color: #81725a;
  background: transparent;
  cursor: pointer;
  font-size: 11px;
}

.cwe-rebuild-link:hover {
  color: var(--gold);
}

/* Secondary screens keep the same dossier language. */
.cwe-section-head {
  margin: 0 36px;
  padding: 29px 24px 18px;
}

.cwe-section-head p {
  font-size: 12px;
}

.cwe-section-head h2 {
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 29px;
}

.cwe-section-head > span {
  font-size: 12px;
}

.cwe-events-ledger,
.cwe-archive-grid {
  min-height: 0;
  margin: 18px 60px 26px;
  overflow: auto;
}

.cwe-ledger-column,
.cwe-archive-column {
  padding-right: 30px;
  padding-left: 30px;
}

.cwe-record > p,
.cwe-hook > p,
.cwe-person p,
.cwe-fact p {
  font-size: 14px;
}

.cwe-record h3,
.cwe-hook h3,
.cwe-person h3 {
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 18px;
}

/* Settings remains a drawer, but now reads as a matching control folio. */
.cwe-drawer-backdrop {
  position: absolute;
  z-index: 30;
  inset: 0;
  background: rgba(5, 5, 4, 0.66);
  backdrop-filter: blur(2px);
}

.cwe-settings-drawer {
  position: absolute;
  z-index: 35;
  top: 0;
  right: 0;
  bottom: 0;
  width: min(590px, 44vw);
  border-left: 1px solid rgba(190, 151, 91, 0.48);
  background-color: #17140f;
  background-image: url('__LEDGER_TEXTURE__');
  background-position: center;
  background-size: 720px 720px;
  box-shadow: -28px 0 70px rgba(0, 0, 0, 0.58);
}

.cwe-drawer-head {
  min-height: 102px;
  padding: 22px 28px;
  border-bottom-color: var(--line-strong);
  background: rgba(12, 10, 8, 0.88);
}

.cwe-drawer-head h2 {
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 28px;
}

.cwe-settings-scroll {
  padding: 0 28px 34px;
}

.cwe-settings-section {
  padding: 24px 0;
}

.cwe-settings-section h3 {
  font-family: 'STSong', 'Songti SC', serif;
  font-size: 20px;
}

.cwe-mode-switch label,
.cwe-current-connection,
.cwe-field input,
.cwe-field select,
.cwe-field-row input,
.cwe-field-row select,
.cwe-field-action button,
.cwe-actions-row button {
  border-radius: 0;
  background-color: #12100c;
}

@media (max-width: 1450px) {
  .cwe-header {
    padding-right: 36px;
    padding-left: 42px;
  }

  .cwe-brand-title {
    gap: 20px;
  }

  .cwe-brand p {
    max-width: 220px;
  }

  .cwe-connection {
    max-width: 380px;
  }

  .cwe-overview-lead {
    gap: 36px;
    grid-template-columns: minmax(320px, 390px) minmax(0, 1fr);
    padding-right: 230px;
  }

  .cwe-statline {
    gap: 16px 24px;
    grid-template-columns: repeat(2, minmax(120px, auto));
  }

  .cwe-event-row {
    grid-template-columns: 128px minmax(0, 1fr) minmax(235px, 0.58fr);
  }

  .cwe-ledger-layout {
    grid-template-columns: minmax(0, 1fr) 325px;
  }
}

@media (max-width: 1120px) {
  .cwe-panel {
    grid-template-rows: 84px minmax(0, 1fr);
  }

  .cwe-header {
    min-height: 84px;
    gap: 16px;
    padding: 0 30px;
  }

  .cwe-brand-mark {
    width: 52px;
    height: 52px;
    flex-basis: 52px;
  }

  .cwe-brand p,
  .cwe-live,
  .cwe-header-actions > button[data-tab='settings'] {
    display: none;
  }

  .cwe-connection {
    max-width: 310px;
    font-size: 12px;
  }

  .cwe-overview-lead {
    min-height: 172px;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    padding: 22px 180px 22px 42px;
  }

  .cwe-duty-strip {
    display: none;
  }

  .cwe-ledger-layout {
    grid-template-columns: minmax(0, 1fr) 300px;
    padding-left: 40px;
  }

  .cwe-event-row {
    gap: 16px;
    grid-template-columns: 112px minmax(0, 1fr);
  }

  .cwe-event-detail {
    display: none;
  }

  .cwe-command-main {
    left: 36px;
    width: min(760px, 84vw);
    grid-template-columns: minmax(360px, 1fr) 58px 190px;
  }
}

@media (max-width: 820px) {
  .cwe-panel {
    grid-template-rows: 76px minmax(0, 1fr);
  }

  .cwe-header {
    min-height: 76px;
    margin: 0 18px;
    padding: 0 18px;
  }

  .cwe-brand-mark {
    width: 46px;
    height: 46px;
    flex-basis: 46px;
  }

  .cwe-brand h1 {
    font-size: 27px;
  }

  .cwe-title-seal,
  .cwe-connection,
  .cwe-header-actions > button[data-tab='settings'] {
    display: none;
  }

  .cwe-content {
    display: block;
    overflow: auto;
    padding: 0 22px;
  }

  .cwe-overview-lead {
    min-height: 165px;
    gap: 18px;
    grid-template-columns: 1fr;
    padding: 22px 28px;
  }

  .cwe-overview-status {
    display: none;
  }

  .cwe-ledger-layout {
    display: block;
    overflow: visible;
    padding-left: 28px;
  }

  .cwe-ledger-main {
    display: block;
    padding-right: 28px;
  }

  .cwe-event-list {
    overflow: visible;
  }

  .cwe-event-row {
    grid-template-columns: 102px minmax(0, 1fr);
  }

  .cwe-event-story h4 {
    font-size: 19px;
  }

  .cwe-event-story p {
    font-size: 13px;
  }

  .cwe-margin-notes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--line-strong);
    border-left: 0;
    overflow: visible;
  }

  .cwe-margin-notes section {
    min-height: 0;
    border-right: 1px solid var(--line);
  }

  .cwe-shell {
    grid-template-rows: minmax(0, 1fr) 112px;
  }

  .cwe-command-bar {
    min-height: 112px;
    padding: 8px 22px;
  }

  .cwe-command-main {
    left: 0;
    width: 100%;
    height: 48px;
    gap: 7px;
    grid-template-columns: minmax(0, 1fr) 62px 145px;
  }

  .cwe-command-bar nav button,
  .cwe-settings-key,
  .cwe-command-main > .primary {
    padding: 0 8px;
    font-size: 13px;
  }

  .cwe-command-bar > p {
    gap: 12px;
    font-size: 9px;
  }

  .cwe-settings-drawer {
    width: calc(100% - 18px);
  }
}

@media (max-width: 560px) {
  .cwe-header {
    margin: 0 12px;
    padding: 0 14px;
  }

  .cwe-brand {
    gap: 9px;
  }

  .cwe-brand h1 {
    font-size: 23px;
  }

  .cwe-header-actions {
    gap: 8px;
    padding-right: 4px;
  }

  .cwe-content {
    padding: 0 14px;
  }

  .cwe-overview-lead {
    padding: 20px;
  }

  .cwe-world-brief h2 {
    font-size: 21px;
  }

  .cwe-ledger-layout {
    padding-left: 18px;
  }

  .cwe-ledger-main {
    padding-right: 18px;
  }

  .cwe-event-row {
    min-height: 110px;
    grid-template-columns: 76px minmax(0, 1fr);
  }

  .cwe-event-when {
    padding-left: 27px;
  }

  .cwe-event-when::before {
    left: 8px;
  }

  .cwe-event-when i {
    left: 1px;
    width: 15px;
    height: 15px;
  }

  .cwe-event-when strong {
    font-size: 14px;
  }

  .cwe-event-when b,
  .cwe-event-when span {
    font-size: 11px;
  }

  .cwe-event-story h4 {
    font-size: 16px;
  }

  .cwe-event-story p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .cwe-margin-notes {
    display: block;
  }

  .cwe-margin-notes section {
    padding: 22px 20px;
    border-right: 0;
  }

  .cwe-command-main {
    grid-template-columns: minmax(0, 1fr) 54px 116px;
  }

  .cwe-command-bar > p span:nth-child(2) {
    display: none;
  }
}
