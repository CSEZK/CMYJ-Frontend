:root {
  color-scheme: dark;
  --paper: #17130f;
  --paper-raised: #1d1813;
  --paper-deep: #100d0a;
  --ink: #ead9ba;
  --ink-bright: #fff0d2;
  --muted: #ad9a7b;
  --faint: #746653;
  --line: rgba(205, 170, 111, 0.2);
  --line-strong: rgba(205, 170, 111, 0.38);
  --cinnabar: #b54d39;
  --cinnabar-bright: #db7258;
  --gold: #c79b5d;
  --jade: #78998e;
  --shadow: rgba(0, 0, 0, 0.62);
  font-family: 'Microsoft YaHei', 'PingFang SC', 'Noto Sans CJK SC', 'Source Han Sans SC', sans-serif;
}

* {
  box-sizing: border-box;
}

html,
body,
#cwe-root {
  width: 100%;
  height: 100%;
  margin: 0;
  overflow: hidden;
  color: var(--ink);
  background: transparent;
}

button,
input,
select {
  font: inherit;
}

button:focus-visible,
input:focus-visible,
select:focus-visible {
  outline: 2px solid var(--gold);
  outline-offset: 2px;
}

.cwe-panel {
  position: relative;
  display: flex;
  height: 100%;
  flex-direction: column;
  overflow: hidden;
  border: 1px solid var(--line-strong);
  border-radius: 10px;
  background-color: var(--paper);
  background-image: url('__LEDGER_TEXTURE__');
  background-repeat: repeat;
  background-size: 620px 620px;
  box-shadow:
    0 28px 90px var(--shadow),
    inset 0 0 0 4px rgba(205, 170, 111, 0.035);
}

.cwe-panel::after {
  position: absolute;
  z-index: 10;
  inset: 8px;
  border: 1px solid rgba(205, 170, 111, 0.08);
  content: '';
  pointer-events: none;
}

.cwe-header {
  position: relative;
  z-index: 20;
  display: flex;
  min-height: 78px;
  align-items: center;
  justify-content: space-between;
  gap: 22px;
  padding: 13px 24px;
  border-bottom: 1px solid var(--line);
  background: rgba(13, 10, 8, 0.76);
  box-shadow: 0 10px 28px rgba(0, 0, 0, 0.16);
  backdrop-filter: blur(10px);
}

.cwe-brand {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 13px;
}

.cwe-brand-mark {
  display: grid;
  width: 46px;
  height: 46px;
  flex: 0 0 46px;
  place-items: center;
  border: 1px solid rgba(199, 155, 93, 0.62);
  border-radius: 50%;
  color: var(--gold);
  background: rgba(16, 13, 10, 0.74);
  box-shadow: inset 0 0 0 4px rgba(199, 155, 93, 0.05);
}

.cwe-brand-mark .cwe-compass {
  width: 37px;
  height: 37px;
}

.cwe-brand-mark .cwe-compass-ring,
.cwe-brand-mark .cwe-compass-ticks {
  fill: none;
  stroke: currentColor;
  stroke-width: 1.25;
}

.cwe-brand-mark .cwe-compass-ring-inner {
  opacity: 0.42;
}

.cwe-brand-mark .cwe-compass-needle-north {
  fill: var(--cinnabar-bright);
}

.cwe-brand-mark .cwe-compass-needle-south {
  fill: var(--jade);
}

.cwe-brand-mark .cwe-compass-pin {
  fill: var(--gold);
}

.cwe-brand h1,
.cwe-brand p {
  margin: 0;
}

.cwe-brand h1 {
  color: var(--ink-bright);
  font-family: 'Noto Serif CJK SC', 'Source Han Serif SC', 'Songti SC', serif;
  font-size: 25px;
  font-weight: 700;
  letter-spacing: 0.14em;
}

.cwe-brand p {
  margin-top: 3px;
  overflow: hidden;
  color: var(--muted);
  font-size: 11px;
  letter-spacing: 0.04em;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-header-actions,
.cwe-connection,
.cwe-live {
  display: flex;
  align-items: center;
}

.cwe-header-actions {
  min-width: 0;
  gap: 18px;
}

.cwe-connection {
  min-width: 0;
  max-width: 390px;
  gap: 8px;
  color: var(--muted);
  font-size: 10px;
}

.cwe-connection i,
.cwe-live i {
  width: 7px;
  height: 7px;
  flex: 0 0 7px;
  border-radius: 50%;
  background: var(--jade);
  box-shadow: 0 0 0 3px rgba(120, 153, 142, 0.12);
}

.cwe-connection span,
.cwe-connection b {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-connection b {
  max-width: 190px;
  color: var(--ink);
  font-weight: 500;
}

.cwe-live {
  gap: 7px;
  color: var(--muted);
  font-size: 11px;
  white-space: nowrap;
}

.cwe-live i {
  background: var(--faint);
  box-shadow: 0 0 0 3px rgba(116, 102, 83, 0.12);
}

.cwe-live.on i {
  background: var(--jade);
  box-shadow:
    0 0 0 3px rgba(120, 153, 142, 0.12),
    0 0 10px rgba(120, 153, 142, 0.5);
}

.cwe-live.busy i {
  background: var(--gold);
  animation: cwe-pulse 1s infinite;
}

.cwe-live.error i {
  background: var(--cinnabar-bright);
}

.cwe-header-actions > button,
.cwe-drawer-head > button {
  border: 0;
  border-bottom: 1px solid transparent;
  color: var(--muted);
  background: transparent;
  cursor: pointer;
  font-size: 11px;
  letter-spacing: 0.08em;
}

.cwe-header-actions > button:hover,
.cwe-drawer-head > button:hover {
  border-bottom-color: var(--cinnabar-bright);
  color: var(--ink-bright);
}

.cwe-shell {
  position: relative;
  z-index: 1;
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
}

.cwe-content {
  min-width: 0;
  min-height: 0;
  flex: 1;
  overflow: auto;
  padding: 26px 32px 22px;
  scrollbar-color: rgba(199, 155, 93, 0.3) transparent;
}

.cwe-overview-lead {
  display: grid;
  align-items: end;
  gap: 24px;
  grid-template-columns: minmax(0, 1fr) auto;
  padding: 0 0 22px;
  border-bottom: 1px solid var(--line-strong);
}

.cwe-brief-kicker {
  display: flex;
  align-items: center;
  gap: 16px;
  color: var(--gold);
  font-size: 11px;
  letter-spacing: 0.12em;
}

.cwe-brief-kicker span:first-child {
  padding-bottom: 5px;
  border-bottom: 1px solid var(--cinnabar);
  color: var(--ink-bright);
  font-weight: 700;
}

.cwe-world-brief h2 {
  max-width: 880px;
  margin: 12px 0 8px;
  color: var(--ink-bright);
  font-family: 'Noto Serif CJK SC', 'Source Han Serif SC', 'Songti SC', serif;
  font-size: clamp(20px, 2vw, 29px);
  font-weight: 650;
  letter-spacing: 0.035em;
  line-height: 1.5;
}

.cwe-world-brief > p {
  margin: 0;
  color: var(--muted);
  font-size: 11px;
}

.cwe-statline {
  display: grid;
  gap: 9px 22px;
  grid-template-columns: repeat(2, auto);
  padding-bottom: 2px;
}

.cwe-statline span {
  display: flex;
  align-items: center;
  gap: 7px;
  color: var(--muted);
  font-size: 11px;
  white-space: nowrap;
}

.cwe-statline i {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--faint);
}

.cwe-statline i.danger {
  background: var(--cinnabar-bright);
  box-shadow: 0 0 8px rgba(219, 114, 88, 0.5);
}

.cwe-statline i.busy {
  background: var(--gold);
}

.cwe-statline i.safe {
  background: var(--jade);
}

.cwe-statline b {
  min-width: 1.6em;
  color: var(--ink-bright);
  font-size: 13px;
  text-align: right;
}

.cwe-notice {
  display: flex;
  align-items: flex-start;
  gap: 11px;
  margin: 14px 0 0;
  padding: 10px 0 0;
  color: var(--muted);
  font-size: 11px;
}

.cwe-notice > i {
  width: 7px;
  height: 7px;
  flex: 0 0 7px;
  margin-top: 5px;
  border-radius: 50%;
  background: var(--jade);
}

.cwe-notice.danger > i {
  background: var(--cinnabar-bright);
}

.cwe-notice b,
.cwe-notice p {
  margin: 0;
}

.cwe-notice p {
  margin-top: 2px;
}

.cwe-ledger-layout {
  display: grid;
  align-items: start;
  gap: 0;
  grid-template-columns: minmax(0, 1fr) 310px;
  margin-top: 20px;
  border-top: 1px solid rgba(205, 170, 111, 0.08);
  border-bottom: 1px solid rgba(205, 170, 111, 0.08);
}

.cwe-ledger-main {
  min-width: 0;
  padding-right: 26px;
}

.cwe-ledger-head,
.cwe-ledger-column > header,
.cwe-archive-column > header,
.cwe-settings-section > header,
.cwe-record > header,
.cwe-hook > header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
}

.cwe-ledger-head {
  align-items: end;
  min-height: 62px;
  padding: 12px 0 11px;
  border-bottom: 1px solid var(--line);
}

.cwe-ledger-head small,
.cwe-ledger-column > header span,
.cwe-archive-column header small,
.cwe-settings-section header small,
.cwe-record header small {
  color: var(--gold);
  font-size: 9px;
  letter-spacing: 0.1em;
}

.cwe-ledger-head h3,
.cwe-ledger-column h3,
.cwe-archive-column h3,
.cwe-settings-section h3,
.cwe-record h3,
.cwe-hook h3 {
  margin: 3px 0 0;
  color: var(--ink-bright);
  font-size: 17px;
}

.cwe-ledger-head button {
  border: 0;
  color: var(--muted);
  background: transparent;
  cursor: pointer;
  font-size: 10px;
}

.cwe-ledger-head button:hover {
  color: var(--gold);
}

.cwe-event-row {
  position: relative;
  display: grid;
  min-width: 0;
  gap: 18px;
  grid-template-columns: 112px minmax(0, 1fr) minmax(190px, 0.62fr);
  padding: 17px 0;
  border-bottom: 1px solid var(--line);
}

.cwe-event-row:last-child {
  border-bottom: 0;
}

.cwe-event-when {
  position: relative;
  display: grid;
  align-content: start;
  gap: 5px;
  padding-left: 22px;
}

.cwe-event-when::before {
  position: absolute;
  top: -17px;
  bottom: -18px;
  left: 4px;
  width: 1px;
  background: rgba(205, 170, 111, 0.22);
  content: '';
}

.cwe-event-when i {
  position: absolute;
  z-index: 1;
  top: 3px;
  left: 0;
  width: 9px;
  height: 9px;
  border: 2px solid var(--paper);
  border-radius: 50%;
  background: var(--jade);
  box-shadow: 0 0 0 1px var(--jade);
}

.cwe-event-row.danger .cwe-event-when i {
  background: var(--cinnabar-bright);
  box-shadow:
    0 0 0 1px var(--cinnabar-bright),
    0 0 9px rgba(219, 114, 88, 0.42);
}

.cwe-event-row.busy .cwe-event-when i {
  background: var(--gold);
  box-shadow: 0 0 0 1px var(--gold);
}

.cwe-event-when strong {
  color: var(--gold);
  font-size: 11px;
  font-weight: 600;
}

.cwe-event-when span {
  overflow: hidden;
  color: var(--muted);
  font-size: 10px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-event-story {
  min-width: 0;
}

.cwe-event-story header {
  display: flex;
  align-items: center;
  gap: 9px;
}

.cwe-event-story h4,
.cwe-event-story p {
  margin: 0;
}

.cwe-event-story h4 {
  overflow: hidden;
  color: var(--ink-bright);
  font-size: 15px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-event-story p {
  margin-top: 7px;
  color: var(--muted);
  font-size: 11px;
  line-height: 1.7;
}

.cwe-event-detail {
  display: grid;
  align-content: start;
  gap: 7px;
  margin: 0;
}

.cwe-event-detail > div {
  display: grid;
  gap: 8px;
  grid-template-columns: 32px minmax(0, 1fr);
}

.cwe-event-detail dt,
.cwe-event-detail dd {
  margin: 0;
  font-size: 10px;
  line-height: 1.55;
}

.cwe-event-detail dt {
  color: var(--gold);
}

.cwe-event-detail dd {
  overflow: hidden;
  color: var(--muted);
  text-overflow: ellipsis;
}

.cwe-margin-notes {
  min-width: 0;
  border-left: 1px solid var(--line-strong);
}

.cwe-margin-notes section {
  padding: 18px 0 20px 24px;
  border-bottom: 1px solid var(--line);
}

.cwe-margin-notes section:last-child {
  border-bottom: 0;
}

.cwe-margin-notes header,
.cwe-margin-notes footer {
  display: flex;
  justify-content: space-between;
  gap: 10px;
}

.cwe-margin-notes header small {
  color: var(--gold);
  font-size: 10px;
}

.cwe-margin-notes header b {
  color: var(--cinnabar-bright);
  font-size: 10px;
  font-weight: 600;
}

.cwe-margin-notes h3 {
  margin: 14px 0 7px;
  color: var(--ink-bright);
  font-size: 14px;
}

.cwe-margin-notes p {
  margin: 0;
  color: var(--muted);
  font-size: 11px;
  line-height: 1.75;
}

.cwe-margin-notes footer {
  margin-top: 13px;
  padding-top: 10px;
  border-top: 1px solid var(--line);
  color: var(--faint);
  font-size: 9px;
}

.cwe-tag {
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--line);
  border-radius: 3px;
  padding: 2px 7px;
  color: var(--muted);
  background: rgba(0, 0, 0, 0.12);
  font-size: 9px;
  white-space: nowrap;
}

.cwe-tag.safe {
  border-color: rgba(120, 153, 142, 0.42);
  color: #92b1a7;
}

.cwe-tag.busy {
  border-color: rgba(199, 155, 93, 0.45);
  color: var(--gold);
}

.cwe-tag.danger,
.cwe-tag.hook {
  border-color: rgba(181, 77, 57, 0.5);
  color: var(--cinnabar-bright);
}

.cwe-command-bar {
  position: relative;
  z-index: 4;
  display: grid;
  flex: 0 0 auto;
  align-items: center;
  gap: 0 18px;
  grid-template-columns: minmax(0, 1fr) auto;
  padding: 9px 24px 7px;
  border-top: 1px solid var(--line-strong);
  background: rgba(12, 9, 7, 0.88);
  box-shadow: 0 -16px 34px rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(12px);
}

.cwe-command-bar nav,
.cwe-command-actions {
  display: flex;
  align-items: center;
}

.cwe-command-bar nav {
  max-width: 660px;
  border: 1px solid var(--line);
}

.cwe-command-bar nav button {
  min-width: 92px;
  border: 0;
  border-right: 1px solid var(--line);
  padding: 9px 18px;
  color: var(--muted);
  background: transparent;
  cursor: pointer;
  font-size: 12px;
  letter-spacing: 0.08em;
}

.cwe-command-bar nav button:last-child {
  border-right: 0;
}

.cwe-command-bar nav button:hover,
.cwe-command-bar nav button.active {
  color: var(--ink-bright);
  background: rgba(199, 155, 93, 0.08);
}

.cwe-command-bar nav button.active {
  box-shadow: inset 0 -2px 0 var(--cinnabar);
}

.cwe-command-actions {
  gap: 8px;
}

.cwe-command-actions button,
.cwe-actions-row button {
  border: 1px solid var(--line);
  border-radius: 3px;
  padding: 9px 14px;
  color: var(--ink);
  background: rgba(16, 13, 10, 0.72);
  cursor: pointer;
  font-size: 11px;
}

.cwe-command-actions button:hover,
.cwe-actions-row button:hover {
  border-color: var(--gold);
}

.cwe-command-actions button.primary,
.cwe-actions-row button.primary {
  min-width: 132px;
  border-color: rgba(219, 114, 88, 0.72);
  color: #fff2df;
  background: #8f382d;
  box-shadow: inset 0 0 0 2px rgba(255, 232, 199, 0.05);
}

.cwe-command-actions button:disabled,
.cwe-actions-row button:disabled {
  cursor: wait;
  opacity: 0.52;
}

.cwe-command-bar > p {
  display: flex;
  justify-content: center;
  gap: 24px;
  grid-column: 1 / -1;
  margin: 6px 0 0;
  color: var(--faint);
  font-size: 9px;
}

.cwe-section-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--line-strong);
}

.cwe-section-head p,
.cwe-section-head h2 {
  margin: 0;
}

.cwe-section-head p {
  color: var(--gold);
  font-size: 10px;
  letter-spacing: 0.12em;
}

.cwe-section-head h2 {
  margin-top: 4px;
  color: var(--ink-bright);
  font-family: 'Noto Serif CJK SC', 'Source Han Serif SC', 'Songti SC', serif;
  font-size: 25px;
}

.cwe-section-head > span {
  color: var(--muted);
  font-size: 10px;
}

.cwe-events-ledger,
.cwe-archive-grid {
  display: grid;
  min-height: 0;
  margin-top: 18px;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}

.cwe-events-ledger {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.cwe-ledger-column,
.cwe-archive-column {
  min-width: 0;
  padding: 0 22px 12px;
  border-right: 1px solid var(--line-strong);
}

.cwe-ledger-column:first-child,
.cwe-archive-column:first-child {
  padding-left: 0;
}

.cwe-ledger-column:last-child,
.cwe-archive-column:last-child {
  padding-right: 0;
  border-right: 0;
}

.cwe-ledger-column > header,
.cwe-archive-column > header {
  align-items: center;
  min-height: 58px;
  border-bottom: 1px solid var(--line);
}

.cwe-stack {
  display: grid;
}

.cwe-record {
  padding: 15px 0;
  border-bottom: 1px solid var(--line);
}

.cwe-record:last-child {
  border-bottom: 0;
}

.cwe-record > p,
.cwe-hook > p {
  margin: 8px 0 0;
  color: var(--muted);
  font-size: 11px;
  line-height: 1.75;
}

.cwe-record footer {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-top: 10px;
  color: var(--faint);
  font-size: 9px;
}

.cwe-archive-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.cwe-scroll-list {
  max-height: calc(100vh - 270px);
  overflow: auto;
  scrollbar-color: rgba(199, 155, 93, 0.24) transparent;
}

.cwe-person,
.cwe-fact,
.cwe-hook {
  padding: 13px 0;
  border-bottom: 1px solid var(--line);
}

.cwe-person {
  display: grid;
  gap: 11px;
  grid-template-columns: 34px minmax(0, 1fr);
}

.cwe-avatar,
.cwe-empty span {
  display: grid;
  place-items: center;
  border: 1px solid var(--line-strong);
  color: var(--gold);
  background: rgba(199, 155, 93, 0.05);
}

.cwe-avatar {
  width: 34px;
  height: 34px;
  border-radius: 3px;
  font-family: 'Noto Serif CJK SC', 'Source Han Serif SC', 'Songti SC', serif;
}

.cwe-person h3,
.cwe-person p {
  margin: 0;
}

.cwe-person h3 {
  color: var(--ink-bright);
  font-size: 12px;
}

.cwe-person small,
.cwe-hook small,
.cwe-fact small {
  color: var(--gold);
  font-size: 9px;
}

.cwe-person p,
.cwe-fact p {
  margin: 4px 0 0;
  color: var(--muted);
  font-size: 10px;
  line-height: 1.65;
}

.cwe-fact {
  display: grid;
  gap: 9px;
  grid-template-columns: 8px minmax(0, 1fr);
}

.cwe-fact > i {
  width: 7px;
  height: 7px;
  margin-top: 5px;
  border: 1px solid var(--gold);
  border-radius: 50%;
}

.cwe-fact > i.confirmed {
  border-color: var(--jade);
  background: var(--jade);
}

.cwe-empty {
  display: grid;
  min-height: 130px;
  place-items: center;
  align-content: center;
  color: var(--faint);
  text-align: center;
}

.cwe-empty span {
  width: 34px;
  height: 34px;
  border-radius: 50%;
}

.cwe-empty p {
  margin: 9px 0 0;
  font-size: 10px;
}

.cwe-drawer-backdrop {
  position: absolute;
  z-index: 30;
  inset: 0;
  border: 0;
  background: rgba(7, 5, 4, 0.68);
  cursor: default;
  backdrop-filter: blur(2px);
}

.cwe-settings-drawer {
  position: absolute;
  z-index: 31;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  width: min(570px, calc(100% - 42px));
  flex-direction: column;
  border-left: 1px solid var(--line-strong);
  background-color: #18130f;
  background-image: url('__LEDGER_TEXTURE__');
  background-size: 620px 620px;
  box-shadow: -26px 0 70px rgba(0, 0, 0, 0.44);
  animation: cwe-drawer-in 0.22s ease-out both;
}

.cwe-drawer-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  padding: 24px 26px 18px;
  border-bottom: 1px solid var(--line-strong);
  background: rgba(13, 10, 8, 0.48);
}

.cwe-drawer-head small,
.cwe-drawer-head h2,
.cwe-drawer-head p {
  margin: 0;
}

.cwe-drawer-head small {
  color: var(--gold);
  font-size: 10px;
  letter-spacing: 0.12em;
}

.cwe-drawer-head h2 {
  margin-top: 4px;
  color: var(--ink-bright);
  font-family: 'Noto Serif CJK SC', 'Source Han Serif SC', 'Songti SC', serif;
  font-size: 25px;
}

.cwe-drawer-head p {
  margin-top: 5px;
  color: var(--muted);
  font-size: 10px;
}

.cwe-settings-scroll {
  min-height: 0;
  flex: 1;
  overflow: auto;
  padding: 0 26px 28px;
}

.cwe-settings-section {
  padding: 20px 0;
  border-bottom: 1px solid var(--line-strong);
}

.cwe-settings-section:last-child {
  border-bottom: 0;
}

.cwe-mode-switch {
  display: grid;
  gap: 9px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 14px;
}

.cwe-mode-switch label {
  position: relative;
  cursor: pointer;
}

.cwe-mode-switch input {
  position: absolute;
  opacity: 0;
}

.cwe-mode-switch span {
  display: grid;
  gap: 3px;
  min-height: 60px;
  padding: 11px 12px;
  border: 1px solid var(--line);
  background: rgba(12, 9, 7, 0.28);
}

.cwe-mode-switch b {
  color: var(--ink);
  font-size: 11px;
}

.cwe-mode-switch small {
  color: var(--muted);
  font-size: 9px;
}

.cwe-mode-switch input:checked + span {
  border-color: rgba(120, 153, 142, 0.62);
  box-shadow: inset 3px 0 0 var(--jade);
}

.cwe-connection-pane {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--line);
}

.cwe-connection-pane[hidden],
.cwe-field > select[hidden] {
  display: none;
}

.cwe-current-connection {
  display: grid;
  align-items: stretch;
  gap: 9px;
  grid-template-columns: repeat(2, minmax(0, 1fr)) auto;
}

.cwe-current-connection > div {
  min-width: 0;
  padding: 9px 10px;
  border-left: 2px solid rgba(120, 153, 142, 0.62);
  background: rgba(120, 153, 142, 0.05);
}

.cwe-current-connection small,
.cwe-current-connection strong {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-current-connection small {
  color: var(--muted);
  font-size: 8px;
}

.cwe-current-connection strong {
  margin-top: 3px;
  color: var(--ink);
  font-size: 10px;
}

.cwe-current-connection button,
.cwe-field-action button {
  border: 1px solid var(--line);
  color: var(--gold);
  background: transparent;
  cursor: pointer;
  font-size: 9px;
}

.cwe-field,
.cwe-field-row label {
  display: grid;
  gap: 5px;
  margin-top: 10px;
}

.cwe-field > span,
.cwe-field-row label > span {
  color: var(--muted);
  font-size: 9px;
}

.cwe-field-row {
  display: grid;
  gap: 9px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.cwe-field input,
.cwe-field select,
.cwe-field-row input,
.cwe-field-row select {
  width: 100%;
  min-width: 0;
  border: 1px solid var(--line);
  border-radius: 2px;
  padding: 8px 9px;
  color: var(--ink);
  outline: 0;
  background: rgba(9, 7, 5, 0.58);
  font-size: 10px;
}

.cwe-field input:focus,
.cwe-field select:focus,
.cwe-field-row input:focus,
.cwe-field-row select:focus {
  border-color: var(--gold);
}

.cwe-field-action {
  display: grid;
  gap: 7px;
  grid-template-columns: minmax(0, 1fr) auto;
}

.cwe-help,
.cwe-model-status {
  margin: 9px 0 0;
  color: var(--faint);
  font-size: 9px;
  line-height: 1.6;
}

.cwe-help.danger,
.cwe-model-status.error,
.cwe-actions-row button.danger {
  color: var(--cinnabar-bright);
}

.cwe-model-status.success {
  color: #92b1a7;
}

.cwe-check {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 13px 0;
  color: var(--muted);
  font-size: 10px;
}

.cwe-check input {
  accent-color: var(--cinnabar);
}

.cwe-switch {
  position: relative;
  width: 39px;
  height: 21px;
}

.cwe-switch input {
  position: absolute;
  opacity: 0;
}

.cwe-switch i {
  position: absolute;
  inset: 0;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.26);
  cursor: pointer;
}

.cwe-switch i::after {
  position: absolute;
  top: 3px;
  left: 3px;
  width: 13px;
  height: 13px;
  border-radius: 50%;
  background: var(--muted);
  content: '';
  transition:
    left 0.18s,
    background 0.18s;
}

.cwe-switch input:checked + i {
  border-color: rgba(120, 153, 142, 0.55);
}

.cwe-switch input:checked + i::after {
  left: 21px;
  background: var(--jade);
}

.cwe-actions-row {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-top: 15px;
}

.cwe-content::-webkit-scrollbar,
.cwe-scroll-list::-webkit-scrollbar,
.cwe-settings-scroll::-webkit-scrollbar {
  width: 7px;
}

.cwe-content::-webkit-scrollbar-thumb,
.cwe-scroll-list::-webkit-scrollbar-thumb,
.cwe-settings-scroll::-webkit-scrollbar-thumb {
  border-radius: 8px;
  background: rgba(199, 155, 93, 0.24);
}

@keyframes cwe-pulse {
  50% {
    opacity: 0.35;
    transform: scale(0.78);
  }
}

@keyframes cwe-drawer-in {
  from {
    opacity: 0;
    transform: translateX(28px);
  }
}

@media (max-width: 1180px) {
  .cwe-connection span {
    display: none;
  }

  .cwe-event-row {
    grid-template-columns: 94px minmax(0, 1fr);
  }

  .cwe-event-detail {
    grid-column: 2;
  }

  .cwe-command-bar nav button {
    min-width: 76px;
    padding-inline: 13px;
  }
}

@media (max-width: 900px) {
  .cwe-header {
    min-height: 68px;
    padding: 11px 15px;
  }

  .cwe-brand-mark {
    width: 40px;
    height: 40px;
    flex-basis: 40px;
  }

  .cwe-brand-mark .cwe-compass {
    width: 32px;
    height: 32px;
  }

  .cwe-brand h1 {
    font-size: 20px;
  }

  .cwe-connection,
  .cwe-live {
    display: none;
  }

  .cwe-content {
    padding: 20px 18px;
  }

  .cwe-overview-lead,
  .cwe-ledger-layout {
    grid-template-columns: 1fr;
  }

  .cwe-statline {
    grid-template-columns: repeat(4, auto);
  }

  .cwe-ledger-main {
    padding-right: 0;
  }

  .cwe-margin-notes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--line-strong);
    border-left: 0;
  }

  .cwe-margin-notes section {
    padding: 17px 18px 18px 0;
    border-right: 1px solid var(--line);
    border-bottom: 0;
  }

  .cwe-margin-notes section:last-child {
    padding-right: 0;
    padding-left: 18px;
    border-right: 0;
  }

  .cwe-command-bar {
    padding-inline: 14px;
  }

  .cwe-command-actions button:first-child {
    display: none;
  }

  .cwe-events-ledger,
  .cwe-archive-grid {
    grid-template-columns: 1fr;
  }

  .cwe-ledger-column,
  .cwe-archive-column,
  .cwe-ledger-column:first-child,
  .cwe-archive-column:first-child {
    padding: 0;
    border-right: 0;
    border-bottom: 1px solid var(--line-strong);
  }
}

@media (max-width: 640px) {
  .cwe-panel {
    border-radius: 6px;
  }

  .cwe-brand p,
  .cwe-command-bar > p {
    display: none;
  }

  .cwe-world-brief h2 {
    font-size: 18px;
  }

  .cwe-statline {
    gap: 7px 12px;
    grid-template-columns: repeat(2, auto);
  }

  .cwe-event-row {
    gap: 10px;
    grid-template-columns: 76px minmax(0, 1fr);
  }

  .cwe-event-detail {
    display: none;
  }

  .cwe-margin-notes {
    grid-template-columns: 1fr;
  }

  .cwe-margin-notes section,
  .cwe-margin-notes section:last-child {
    padding: 15px 0;
    border-right: 0;
    border-bottom: 1px solid var(--line);
  }

  .cwe-command-bar {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .cwe-command-bar nav {
    overflow-x: auto;
  }

  .cwe-command-bar nav button {
    min-width: 58px;
    padding: 8px 10px;
    font-size: 10px;
  }

  .cwe-command-actions button.primary {
    min-width: auto;
    padding-inline: 12px;
  }

  .cwe-settings-drawer {
    width: 100%;
  }

  .cwe-mode-switch,
  .cwe-field-row,
  .cwe-current-connection {
    grid-template-columns: 1fr;
  }
}
