/* 天下演化 × 残明余烬状态栏：共享设计语言覆盖层 */

:root {
  --cwe-font-body: 'Microsoft YaHei', 'PingFang SC', 'Noto Sans CJK SC', 'Source Han Sans SC', sans-serif;
  --cwe-font-display: 'Noto Serif SC', 'Source Han Serif SC', 'Songti SC', 'STSong', serif;
  font-family: var(--cwe-font-body);
}

.cwe-panel.theme-day {
  color-scheme: light;
  --paper: #f4e7c7;
  --paper2: #ead6a6;
  --ink: #2c2118;
  --ink-bright: #241910;
  --muted: #75624d;
  --faint: #9a8569;
  --line: rgba(96, 65, 36, 0.22);
  --line-strong: rgba(96, 65, 36, 0.34);
  --accent: #a43d2d;
  --accent-hover: #b64b38;
  --accent2: #6f8a67;
  --warning: #b3823f;
  --card: rgba(255, 248, 226, 0.7);
  --card-strong: rgba(255, 249, 232, 0.88);
  --card-soft: rgba(255, 251, 237, 0.42);
  --bar-track: #e1cfa8;
  --shadow: rgba(55, 31, 12, 0.32);
  --glow: rgba(188, 83, 42, 0.28);
}

.cwe-panel.theme-night {
  color-scheme: dark;
  --paper: #211913;
  --paper2: #352619;
  --ink: #f2dfba;
  --ink-bright: #fff0d2;
  --muted: #b99f76;
  --faint: #806b50;
  --line: rgba(237, 196, 128, 0.2);
  --line-strong: rgba(237, 196, 128, 0.32);
  --accent: #d0784b;
  --accent-hover: #df8657;
  --accent2: #89a074;
  --warning: #c49a55;
  --card: rgba(65, 44, 30, 0.76);
  --card-strong: rgba(71, 48, 32, 0.92);
  --card-soft: rgba(83, 57, 38, 0.42);
  --bar-track: #4a3828;
  --shadow: rgba(0, 0, 0, 0.62);
  --glow: rgba(220, 94, 48, 0.25);
}

.cwe-panel.theme-star {
  color-scheme: dark;
  --paper: #0d1820;
  --paper2: #111d28;
  --ink: #e6dcc8;
  --ink-bright: #f4ead7;
  --muted: #8fa0ae;
  --faint: #61717f;
  --line: rgba(180, 155, 110, 0.2);
  --line-strong: rgba(180, 155, 110, 0.32);
  --accent: #d4a040;
  --accent-hover: #e0ad50;
  --accent2: #5d8d9a;
  --warning: #c49750;
  --card: rgba(18, 28, 38, 0.78);
  --card-strong: rgba(20, 32, 43, 0.92);
  --card-soft: rgba(24, 39, 52, 0.48);
  --bar-track: #162432;
  --shadow: rgba(0, 0, 0, 0.68);
  --glow: rgba(210, 160, 60, 0.2);
}

.cwe-panel.theme-ink {
  color-scheme: light;
  --paper: #eee9dc;
  --paper2: #d8d0bf;
  --ink: #171a17;
  --ink-bright: #101310;
  --muted: #5f6158;
  --faint: #87887e;
  --line: rgba(20, 25, 22, 0.2);
  --line-strong: rgba(20, 25, 22, 0.32);
  --accent: #a12f25;
  --accent-hover: #b03d32;
  --accent2: #2f6965;
  --warning: #a98138;
  --card: rgba(248, 245, 235, 0.62);
  --card-strong: rgba(250, 247, 238, 0.86);
  --card-soft: rgba(250, 248, 240, 0.42);
  --bar-track: #cac1ad;
  --shadow: rgba(25, 30, 24, 0.28);
  --glow: rgba(40, 70, 64, 0.18);
}

html,
body,
#cwe-root {
  font-family: var(--cwe-font-body);
}

button,
input,
select {
  font-family: inherit;
}

button {
  transition:
    color 0.18s ease,
    background 0.18s ease,
    border-color 0.18s ease,
    box-shadow 0.18s ease,
    transform 0.18s ease;
}

button:focus-visible,
input:focus-visible,
select:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

* {
  scrollbar-color: var(--line-strong) transparent;
  scrollbar-width: thin;
}

*::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

*::-webkit-scrollbar-thumb {
  border: 2px solid transparent;
  border-radius: 999px;
  background: var(--line-strong);
  background-clip: padding-box;
}

.cwe-panel {
  isolation: isolate;
  display: flex;
  flex-direction: column;
  border: 1px solid var(--line);
  border-radius: 22px;
  color: var(--ink);
  background-color: var(--paper);
  background-image: none;
  box-shadow: 0 22px 70px var(--shadow);
  transition:
    background 0.45s ease,
    border-color 0.45s ease,
    box-shadow 0.45s ease,
    color 0.45s ease;
}

.cwe-panel::before {
  display: none;
}

.cwe-panel::after {
  display: none;
}

.cwe-panel.theme-star {
  background-image: none;
}

.cwe-panel.theme-ink {
  border-radius: 12px;
}

.cwe-header {
  position: relative;
  z-index: 4;
  min-height: 76px;
  gap: 18px;
  padding: 15px 20px 14px;
  border-bottom: 1px solid var(--line);
  background: color-mix(in srgb, var(--paper) 78%, transparent);
  box-shadow: none;
  backdrop-filter: blur(12px);
}

.cwe-brand {
  gap: 12px;
}

.cwe-brand-mark {
  width: 44px;
  height: 44px;
  flex-basis: 44px;
  padding: 3px;
  border: 1px solid var(--line-strong);
  border-radius: 50%;
  background: var(--card);
  box-shadow:
    0 7px 18px color-mix(in srgb, var(--shadow) 42%, transparent),
    inset 0 0 0 3px color-mix(in srgb, var(--accent) 7%, transparent);
}

.cwe-brand-mark img {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 2px 4px color-mix(in srgb, var(--shadow) 55%, transparent));
}

.cwe-brand-title > div {
  gap: 8px;
}

.cwe-brand h1 {
  color: var(--ink-bright);
  font-family: var(--cwe-font-display);
  font-size: 24px;
  font-weight: 700;
  letter-spacing: 0.13em;
}

.cwe-brand p {
  margin-top: 4px;
  color: var(--muted);
  font-size: 11px;
  letter-spacing: 0.05em;
}

.cwe-title-seal {
  display: grid;
  width: 23px;
  height: 23px;
  place-items: center;
  border: 1px solid color-mix(in srgb, var(--accent) 72%, var(--line));
  border-radius: 6px;
  color: var(--accent);
  font-family: var(--cwe-font-display);
  font-size: 12px;
  background: color-mix(in srgb, var(--accent) 7%, transparent);
}

.cwe-header-actions {
  gap: 7px;
}

.cwe-connection {
  max-width: 440px;
  gap: 8px;
  padding: 7px 11px;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--muted);
  background: var(--card-soft);
  font-size: 11px;
}

.cwe-connection i,
.cwe-live i {
  background: var(--accent2);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent2) 14%, transparent);
}

.cwe-connection b {
  max-width: 190px;
  color: var(--ink);
  font-weight: 600;
}

.cwe-live {
  gap: 7px;
  padding: 7px 10px;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--muted);
  background: var(--card-soft);
  font-size: 11px;
}

.cwe-live i {
  background: var(--faint);
  box-shadow: none;
}

.cwe-live.on i {
  background: var(--accent2);
  box-shadow: 0 0 8px color-mix(in srgb, var(--accent2) 62%, transparent);
}

.cwe-live.busy i {
  background: var(--warning);
}

.cwe-live.error i {
  background: var(--accent);
}

.cwe-header-actions > button,
.cwe-drawer-head > button {
  min-height: 34px;
  padding: 0 11px;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--muted);
  background: var(--card);
  font-size: 12px;
  letter-spacing: 0.04em;
}

.cwe-header-actions > button:hover,
.cwe-drawer-head > button:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 7%, var(--card));
  transform: translateY(-1px);
}

.cwe-header-actions > button.cwe-close-button,
.cwe-drawer-head > button.cwe-close-button {
  display: grid;
  width: 34px;
  min-width: 34px;
  height: 34px;
  padding: 0;
  place-items: center;
  border-radius: 50%;
  font-family: Arial, sans-serif;
  font-size: 22px;
  font-weight: 300;
  line-height: 1;
}

.cwe-close-button span {
  display: block;
  margin-top: -2px;
}

.cwe-toolbar {
  position: relative;
  z-index: 3;
  display: flex;
  min-height: 51px;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 8px 18px;
  border-bottom: 1px solid var(--line);
  background: color-mix(in srgb, var(--card-soft) 64%, transparent);
}

.cwe-tabs {
  display: flex;
  min-width: 0;
  flex: 1 1 auto;
  gap: 4px;
  padding: 3px;
  border: 1px solid var(--line);
  border-radius: 13px;
  background: var(--card-soft);
}

.cwe-command-bar .cwe-tabs button {
  min-width: 88px;
  flex: 1 1 0;
  padding: 9px 16px;
  border: 1px solid transparent;
  border-radius: 9px;
  color: var(--muted);
  background: transparent;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.08em;
}

.cwe-command-bar .cwe-tabs button:hover {
  border-color: var(--line);
  color: var(--ink);
  background: var(--card-soft);
}

.cwe-command-bar .cwe-tabs button.active {
  border-color: color-mix(in srgb, var(--accent) 46%, var(--line));
  color: #fff;
  background: var(--accent);
  box-shadow: 0 6px 16px var(--glow);
}

.cwe-toolbar-note {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 8px;
  color: var(--muted);
  font-size: 11px;
  white-space: nowrap;
}

.cwe-toolbar-note i {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent2);
}

.cwe-shell {
  display: grid;
  flex: 1;
  min-height: 0;
  grid-template-rows: minmax(0, 1fr) auto;
  background: transparent;
}

.cwe-content {
  padding: 14px;
  background: transparent;
}

.cwe-overview-lead {
  min-height: 0;
  margin-bottom: 12px;
  padding: 18px 20px;
  border: 1px solid var(--line);
  border-radius: 18px;
  background:
    linear-gradient(125deg, color-mix(in srgb, var(--card) 94%, transparent), color-mix(in srgb, var(--accent) 8%, var(--card)));
  box-shadow: 0 12px 28px color-mix(in srgb, var(--shadow) 18%, transparent);
}

.cwe-world-brief::after {
  display: none;
}

.cwe-brief-kicker {
  color: var(--accent);
}

.cwe-brief-kicker span:first-child {
  border-bottom-color: var(--accent);
  color: var(--accent);
}

.cwe-world-brief h2 {
  color: var(--ink-bright);
  font-family: var(--cwe-font-display);
  font-size: clamp(23px, 2.1vw, 32px);
  letter-spacing: 0.06em;
}

.cwe-world-brief > p {
  max-width: 610px;
  color: var(--muted);
  font-size: 14px;
  line-height: 1.75;
}

.cwe-overview-status {
  border-left: 1px solid var(--line);
}

.cwe-statline {
  gap: 9px;
}

.cwe-statline span {
  min-width: 112px;
  padding: 8px 10px;
  border: 1px solid transparent;
  border-radius: 10px;
  color: var(--muted);
  background: color-mix(in srgb, var(--card) 62%, transparent);
}

.cwe-statline span:hover {
  border-color: var(--line);
  background: var(--card);
}

.cwe-statline b {
  color: var(--ink-bright);
}

.cwe-statline i {
  background: var(--faint);
}

.cwe-statline i.danger {
  background: var(--accent);
}

.cwe-statline i.busy {
  background: var(--warning);
}

.cwe-statline i.safe {
  background: var(--accent2);
}

.cwe-duty-strip {
  gap: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--line);
  color: var(--muted);
}

.cwe-duty-strip b {
  color: var(--ink);
}

.cwe-notice {
  margin-bottom: 12px;
  border: 1px solid color-mix(in srgb, var(--accent2) 45%, var(--line));
  border-radius: 14px;
  background: color-mix(in srgb, var(--accent2) 8%, var(--card));
}

.cwe-notice.danger {
  border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
  background: color-mix(in srgb, var(--accent) 8%, var(--card));
}

.cwe-ledger-layout {
  min-height: 0;
  grid-template-columns: minmax(0, 1fr) minmax(260px, 320px);
  gap: 12px;
  border: 0;
  background: transparent;
}

.cwe-ledger-main {
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: 16px;
  background: var(--card-soft);
  box-shadow: 0 10px 24px color-mix(in srgb, var(--shadow) 14%, transparent);
}

.cwe-ledger-head {
  min-height: 55px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--line);
  background: color-mix(in srgb, var(--card) 72%, transparent);
}

.cwe-ledger-head h3,
.cwe-section-head h2,
.cwe-ledger-column > header h3,
.cwe-archive-column > header h3 {
  color: var(--ink-bright);
  font-family: var(--cwe-font-display);
}

.cwe-ledger-head small,
.cwe-section-head p,
.cwe-ledger-column > header small,
.cwe-archive-column > header small {
  color: var(--accent);
}

.cwe-ledger-head button {
  padding: 7px 11px;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--muted);
  background: var(--card);
}

.cwe-ledger-head button:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.cwe-event-list {
  padding: 5px 10px 8px;
}

.cwe-event-row {
  margin: 4px 0;
  border: 1px solid transparent;
  border-radius: 12px;
  background: transparent;
  transition:
    background 0.18s ease,
    border-color 0.18s ease,
    transform 0.18s ease;
}

.cwe-event-row:hover {
  border-color: var(--line);
  background: var(--card);
  transform: translateY(-1px);
}

.cwe-event-row:last-child {
  border-bottom: 1px solid transparent;
}

.cwe-event-when::before {
  background: var(--line);
}

.cwe-event-when i {
  border-color: var(--card-strong);
  background: var(--faint);
  box-shadow: 0 0 0 1px var(--line-strong);
}

.cwe-event-row.danger .cwe-event-when i,
.cwe-event-row.busy .cwe-event-when i {
  background: var(--accent);
  box-shadow:
    0 0 0 1px var(--accent),
    0 0 10px var(--glow);
}

.cwe-event-row.safe .cwe-event-when i {
  background: var(--accent2);
  box-shadow: 0 0 0 1px var(--accent2);
}

.cwe-event-when strong {
  color: var(--accent);
}

.cwe-event-when b,
.cwe-event-when span,
.cwe-event-story p,
.cwe-event-detail dd {
  color: var(--muted);
}

.cwe-event-story h4 {
  color: var(--ink-bright);
  font-family: var(--cwe-font-display);
  font-size: 18px;
}

.cwe-event-story p {
  font-size: 13px;
  line-height: 1.7;
}

.cwe-event-detail dt {
  color: var(--accent);
}

.cwe-event-detail dd {
  font-size: 12px;
}

.cwe-margin-notes {
  display: grid;
  align-content: start;
  gap: 10px;
  border-left: 0;
  background: transparent;
}

.cwe-margin-notes section {
  overflow: hidden;
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 16px;
  background: linear-gradient(155deg, var(--card), var(--card-soft));
  box-shadow: 0 10px 22px color-mix(in srgb, var(--shadow) 13%, transparent);
}

.cwe-margin-notes section::after {
  display: none;
}

.cwe-margin-notes header {
  border-bottom: 1px solid var(--line);
}

.cwe-margin-notes header small,
.cwe-margin-notes header b {
  color: var(--accent);
}

.cwe-margin-notes h3 {
  color: var(--ink-bright);
  font-family: var(--cwe-font-display);
}

.cwe-margin-notes p,
.cwe-margin-notes footer {
  color: var(--muted);
}

.cwe-hook-progress > i {
  border-radius: 999px;
  background: var(--bar-track);
}

.cwe-hook-progress > i > b {
  border-radius: inherit;
  background: linear-gradient(90deg, var(--accent2), var(--accent));
}

.cwe-command-bar {
  position: relative;
  z-index: 3;
  display: flex;
  min-height: 82px;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  gap: 5px;
  padding: 8px 14px 6px;
  border-top: 1px solid var(--line);
  background: color-mix(in srgb, var(--paper) 80%, transparent);
  box-shadow: 0 -9px 26px color-mix(in srgb, var(--shadow) 14%, transparent);
  backdrop-filter: blur(12px);
}

.cwe-command-main {
  display: flex;
  width: min(100%, 860px);
  align-self: center;
  align-items: stretch;
  gap: 8px;
}

.cwe-command-main > .cwe-tabs {
  min-width: 360px;
}

.cwe-command-main > button {
  min-height: 43px;
  padding: 0 17px;
  border: 1px solid var(--line);
  border-radius: 11px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.06em;
}

.cwe-command-main > .cwe-settings-button {
  min-width: 86px;
  color: var(--muted);
  background: var(--card);
}

.cwe-command-main > .cwe-settings-button:hover,
.cwe-command-main > .cwe-settings-button.active {
  border-color: var(--accent);
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 7%, var(--card));
}

.cwe-command-main > .cwe-run-button {
  min-width: 148px;
  border-color: var(--accent);
  color: #fff;
  background: var(--accent);
  box-shadow: 0 7px 18px var(--glow);
}

.cwe-command-main > .cwe-run-button:hover {
  background: var(--accent-hover);
  transform: translateY(-1px);
}

.cwe-command-main > .cwe-run-button:disabled {
  cursor: not-allowed;
  opacity: 0.52;
  transform: none;
}

.cwe-command-meta {
  display: flex;
  width: min(100%, 860px);
  min-height: 18px;
  align-self: center;
  align-items: center;
  justify-content: center;
  gap: 12px;
}

.cwe-command-meta > p {
  display: flex;
  min-width: 0;
  flex-wrap: wrap;
  align-items: center;
  gap: 7px 14px;
  margin: 0;
  color: var(--muted);
  font-size: 11px;
}

.cwe-command-meta > p span {
  white-space: nowrap;
}

.cwe-command-meta > button.cwe-rebuild-link {
  flex: 0 0 auto;
  padding: 2px 7px;
  border: 0;
  border-radius: 6px;
  color: var(--muted);
  background: transparent;
  cursor: pointer;
  font-size: 11px;
}

.cwe-command-meta > button.cwe-rebuild-link:hover {
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 7%, transparent);
}

.cwe-section-head {
  margin: 0 0 12px;
  padding: 4px 3px 13px;
  border-bottom: 1px solid var(--line);
}

.cwe-section-head h2 {
  font-size: 23px;
  letter-spacing: 0.09em;
}

.cwe-section-head > span {
  max-width: 430px;
  color: var(--muted);
}

.cwe-events-ledger,
.cwe-archive-grid {
  gap: 12px;
  border: 0;
  background: transparent;
}

.cwe-ledger-column,
.cwe-archive-column {
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: 16px;
  background: var(--card-soft);
  box-shadow: 0 10px 24px color-mix(in srgb, var(--shadow) 14%, transparent);
}

.cwe-ledger-column > header,
.cwe-archive-column > header {
  padding: 13px 15px;
  border-bottom: 1px solid var(--line);
  background: color-mix(in srgb, var(--card) 72%, transparent);
}

.cwe-record,
.cwe-person,
.cwe-hook,
.cwe-fact {
  margin: 7px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--card);
  box-shadow: 0 6px 16px color-mix(in srgb, var(--shadow) 10%, transparent);
  transition:
    transform 0.18s ease,
    border-color 0.18s ease,
    box-shadow 0.18s ease;
}

.cwe-record:hover,
.cwe-person:hover,
.cwe-hook:hover,
.cwe-fact:hover {
  border-color: color-mix(in srgb, var(--accent) 44%, var(--line));
  box-shadow: 0 10px 22px color-mix(in srgb, var(--shadow) 16%, transparent);
  transform: translateY(-1px);
}

.cwe-record h3,
.cwe-person h3,
.cwe-hook h3 {
  color: var(--ink-bright);
  font-family: var(--cwe-font-display);
}

.cwe-record > p,
.cwe-person p,
.cwe-hook > p,
.cwe-fact p {
  color: var(--muted);
  line-height: 1.65;
}

.cwe-avatar {
  border-radius: 50%;
  color: #fff;
  background: var(--accent);
  box-shadow: 0 5px 14px var(--glow);
}

.cwe-tag {
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 7%, var(--card));
}

.cwe-drawer-backdrop {
  background: color-mix(in srgb, var(--shadow) 52%, transparent);
  backdrop-filter: blur(3px);
}

.cwe-settings-drawer {
  inset: 10px 10px 10px auto;
  width: min(590px, calc(100% - 20px));
  height: auto;
  overflow: hidden;
  border: 1px solid var(--line-strong);
  border-radius: 18px;
  color: var(--ink);
  background: linear-gradient(145deg, var(--paper), var(--paper2));
  box-shadow: 0 22px 70px var(--shadow);
  animation: cwe-integrated-drawer-in 0.24s ease both;
}

@keyframes cwe-integrated-drawer-in {
  from {
    opacity: 0;
    transform: translateX(18px);
  }
}

.cwe-drawer-head {
  padding: 16px 18px;
  border-bottom: 1px solid var(--line);
  background: color-mix(in srgb, var(--card) 62%, transparent);
}

.cwe-drawer-head h2 {
  color: var(--ink-bright);
  font-family: var(--cwe-font-display);
}

.cwe-drawer-head p {
  color: var(--muted);
}

.cwe-settings-scroll {
  padding: 12px;
}

.cwe-settings-section {
  margin: 0 0 10px;
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 15px;
  background: var(--card-soft);
  box-shadow: 0 8px 20px color-mix(in srgb, var(--shadow) 10%, transparent);
}

.cwe-settings-section h3 {
  color: var(--ink-bright);
  font-family: var(--cwe-font-display);
}

.cwe-mode-switch label {
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--card);
}

.cwe-mode-switch label:has(input:checked) {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 8%, var(--card));
  box-shadow: 0 6px 16px var(--glow);
}

.cwe-field input,
.cwe-field select,
.cwe-field-row input,
.cwe-field-row select {
  border: 1px solid var(--line);
  border-radius: 9px;
  color: var(--ink);
  background: var(--card-strong);
  font-size: 12px;
}

.cwe-field input:focus,
.cwe-field select:focus,
.cwe-field-row input:focus,
.cwe-field-row select:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--glow);
}

.cwe-field-action button,
.cwe-actions-row button,
.cwe-current-connection button {
  min-height: 36px;
  border: 1px solid var(--line);
  border-radius: 9px;
  padding: 0 12px;
  color: var(--muted);
  background: var(--card);
  font-size: 11px;
}

.cwe-field-action button:hover,
.cwe-actions-row button:hover,
.cwe-current-connection button:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.cwe-actions-row button.primary {
  border-color: var(--accent);
  color: #fff;
  background: var(--accent);
}

.cwe-actions-row button.danger {
  color: var(--accent);
}

.cwe-current-connection {
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--card);
}

.cwe-current-connection small {
  color: var(--muted);
  font-size: 10px;
}

.cwe-current-connection strong {
  color: var(--ink);
  font-size: 12px;
}

.cwe-field > span,
.cwe-field-row label > span {
  color: var(--muted);
  font-size: 11px;
}

.cwe-help,
.cwe-model-status {
  color: var(--muted);
  font-size: 11px;
  line-height: 1.65;
}

@media (max-width: 1120px) {
  .cwe-header {
    gap: 10px;
  }

  .cwe-connection {
    max-width: 300px;
  }

  .cwe-connection span {
    display: none;
  }

  .cwe-overview-lead {
    grid-template-columns: minmax(0, 1fr);
  }

  .cwe-overview-status {
    padding-left: 0;
    border-top: 1px solid var(--line);
    border-left: 0;
  }

  .cwe-ledger-layout {
    grid-template-columns: minmax(0, 1fr);
  }

  .cwe-margin-notes {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cwe-margin-notes section {
    min-height: 0;
  }
}

@media (max-width: 820px) {
  .cwe-panel,
  .cwe-panel.theme-ink {
    border-radius: 16px;
  }

  .cwe-header {
    min-height: 63px;
    padding: 10px 12px;
  }

  .cwe-brand-mark {
    width: 38px;
    height: 38px;
    flex-basis: 38px;
  }

  .cwe-brand h1 {
    font-size: 20px;
  }

  .cwe-brand p {
    max-width: 250px;
  }

  .cwe-connection {
    display: none;
  }

  .cwe-live {
    padding: 7px 9px;
  }

  .cwe-toolbar {
    overflow-x: auto;
    padding: 7px 10px;
  }

  .cwe-toolbar-note {
    display: none;
  }

  .cwe-content {
    padding: 10px;
  }

  .cwe-overview-lead {
    padding: 15px;
    border-radius: 15px;
  }

  .cwe-statline {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cwe-statline span {
    min-width: 0;
  }

  .cwe-events-ledger,
  .cwe-archive-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .cwe-command-bar {
    align-items: stretch;
  }

  .cwe-command-meta > p span:nth-child(2) {
    display: none;
  }
}

@media (max-width: 600px) {
  .cwe-header {
    gap: 6px;
  }

  .cwe-brand {
    gap: 8px;
  }

  .cwe-brand h1 {
    font-size: 18px;
    letter-spacing: 0.09em;
  }

  .cwe-brand p,
  .cwe-title-seal,
  .cwe-live {
    display: none;
  }

  .cwe-header-actions {
    margin-left: auto;
  }

  .cwe-header-actions > button {
    display: block;
    min-height: 32px;
    padding: 0 9px;
  }

  .cwe-header-actions > button.cwe-close-button {
    display: grid;
    width: 32px;
    min-width: 32px;
    height: 32px;
    padding: 0;
  }

  .cwe-command-bar .cwe-tabs button {
    min-width: 66px;
    padding: 7px 11px;
  }

  .cwe-world-brief h2 {
    font-size: 23px;
  }

  .cwe-world-brief > p {
    font-size: 13px;
  }

  .cwe-overview-status {
    display: grid !important;
    gap: 9px;
    padding-top: 11px;
    border-top: 1px solid var(--line);
  }

  .cwe-statline {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 6px;
  }

  .cwe-statline span {
    padding: 7px 8px;
    font-size: 11px;
  }

  .cwe-duty-strip {
    display: none;
  }

  .cwe-margin-notes {
    grid-template-columns: minmax(0, 1fr);
  }

  .cwe-event-row {
    grid-template-columns: 84px minmax(0, 1fr);
    gap: 8px;
    padding: 12px 9px;
  }

  .cwe-event-when {
    padding-left: 29px;
  }

  .cwe-event-when::before {
    left: 9px;
  }

  .cwe-event-when i {
    left: 2px;
    width: 16px;
    height: 16px;
  }

  .cwe-event-when strong {
    font-size: 14px;
    white-space: nowrap;
  }

  .cwe-event-when b,
  .cwe-event-when span {
    font-size: 11px;
    white-space: nowrap;
  }

  .cwe-event-detail {
    grid-column: 2;
    grid-template-columns: minmax(0, 1fr);
    gap: 5px;
  }

  .cwe-command-bar {
    min-height: 128px;
    gap: 5px;
    padding: 7px 9px 5px;
  }

  .cwe-command-main {
    display: grid;
    width: 100%;
    min-height: 84px;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    grid-template-rows: 40px 38px;
    gap: 6px;
  }

  .cwe-command-main > .cwe-tabs {
    display: grid;
    width: 100%;
    min-width: 0;
    grid-column: 1 / -1;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .cwe-command-main > .cwe-tabs,
  .cwe-command-main > .cwe-tabs button {
    min-height: 40px;
  }

  .cwe-command-main > .cwe-settings-button {
    grid-column: 1 / 3;
  }

  .cwe-command-main > .cwe-run-button {
    min-width: 0;
    grid-column: 3 / -1;
  }

  .cwe-command-main > button {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    justify-content: center;
  }

  .cwe-command-meta {
    width: 100%;
    min-height: 16px;
    justify-content: space-between;
  }

  .cwe-command-meta > p {
    font-size: 10px;
  }

  .cwe-command-meta > p span:not(:first-child) {
    display: none;
  }

  .cwe-settings-drawer {
    inset: 7px;
    width: auto;
    border-radius: 14px;
  }

  .cwe-field-row {
    grid-template-columns: minmax(0, 1fr);
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    scroll-behavior: auto !important;
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* 真实长内容约束：摘要、事件与设置都不能撑坏主框架 */
.cwe-content {
  overflow-x: hidden;
  overflow-y: auto;
  overscroll-behavior: contain;
}

.cwe-overview-lead {
  align-items: center;
  grid-template-columns: minmax(280px, 0.85fr) minmax(430px, 1.15fr);
}

.cwe-world-brief,
.cwe-overview-status,
.cwe-ledger-layout,
.cwe-ledger-main,
.cwe-event-story,
.cwe-event-detail,
.cwe-margin-notes {
  min-width: 0;
}

.cwe-world-brief h2 {
  display: -webkit-box;
  max-width: 760px;
  max-height: 4.65em;
  overflow: hidden;
  margin-block: 10px 7px;
  font-family: var(--cwe-font-body);
  font-size: clamp(18px, 1.45vw, 22px);
  font-weight: 700;
  letter-spacing: 0.035em;
  line-height: 1.55;
  overflow-wrap: anywhere;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.cwe-world-brief > p,
.cwe-event-story p,
.cwe-event-detail dd,
.cwe-margin-notes p {
  overflow-wrap: anywhere;
}

.cwe-event-story p {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.cwe-event-story h4,
.cwe-ledger-head h3,
.cwe-margin-notes h3,
.cwe-section-head h2,
.cwe-ledger-column > header h3,
.cwe-archive-column > header h3,
.cwe-record h3,
.cwe-person h3,
.cwe-hook h3 {
  font-family: var(--cwe-font-body);
}

.cwe-margin-notes p {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 5;
}

.cwe-mode-switch label,
.cwe-mode-switch label:has(input:checked) {
  border: 0;
  background: transparent;
  box-shadow: none;
}

.cwe-mode-switch span {
  height: 100%;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--card);
}

.cwe-mode-switch input:checked + span {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 8%, var(--card));
  box-shadow:
    inset 3px 0 0 var(--accent2),
    0 6px 16px var(--glow);
}

.cwe-current-connection {
  gap: 0;
  overflow: hidden;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.25fr) auto;
}

.cwe-current-connection > div {
  display: grid;
  min-height: 58px;
  align-content: center;
  padding: 10px 12px;
  border: 0;
  border-right: 1px solid var(--line);
  background: transparent;
}

.cwe-current-connection button {
  min-height: 58px;
  border: 0;
  border-radius: 0;
  padding-inline: 14px;
  white-space: nowrap;
}

.cwe-settings-section > header {
  align-items: center;
}

.cwe-field-row {
  align-items: start;
}

@media (max-width: 1120px) {
  .cwe-overview-lead {
    grid-template-columns: minmax(0, 1fr);
  }
}

@media (max-width: 640px) {
  .cwe-current-connection {
    grid-template-columns: minmax(0, 1fr);
  }

  .cwe-current-connection > div {
    border-right: 0;
    border-bottom: 1px solid var(--line);
  }

  .cwe-current-connection button {
    min-height: 42px;
  }
}

/* beta.3：真实内容态统一收口。外框固定，三页只在各自列表内部滚动。 */
#cwe-root,
.cwe-panel {
  font-size: 12px;
}

.cwe-header {
  min-height: 64px;
  flex: 0 0 64px;
  padding: 9px 16px;
}

.cwe-brand {
  gap: 10px;
}

.cwe-brand-mark {
  width: 38px;
  height: 38px;
  flex-basis: 38px;
}

.cwe-brand h1 {
  font-size: 21px;
  letter-spacing: 0.1em;
}

.cwe-brand p {
  max-width: 260px;
  margin-top: 2px;
  overflow: hidden;
  font-size: 10px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cwe-title-seal {
  width: 21px;
  height: 21px;
  font-size: 11px;
}

.cwe-connection,
.cwe-live {
  padding-block: 6px;
  font-size: 10px;
}

.cwe-content {
  display: flex;
  min-height: 0;
  flex-direction: column;
  padding: 11px 12px;
}

.cwe-content-overview .cwe-ledger-layout,
.cwe-content-events .cwe-events-ledger,
.cwe-content-memory .cwe-archive-grid {
  min-height: 0;
  flex: 1 1 auto;
  overflow: hidden;
}

.cwe-overview-lead {
  min-height: 0;
  flex: 0 0 auto;
  grid-template-columns: minmax(300px, 0.92fr) minmax(420px, 1.08fr);
  gap: 16px;
  margin-bottom: 9px;
  padding: 13px 15px;
  border-radius: 14px;
}

.cwe-brief-kicker {
  font-size: 10px;
}

.cwe-world-brief h2 {
  max-height: 4.5em;
  margin-block: 7px 5px;
  font-family: var(--cwe-font-body);
  font-size: 17px;
  font-weight: 700;
  letter-spacing: 0.015em;
  line-height: 1.5;
  -webkit-line-clamp: 3;
}

.cwe-world-brief > p {
  font-size: 10.5px;
  line-height: 1.5;
}

.cwe-overview-status {
  gap: 8px;
  padding-left: 16px;
}

.cwe-statline {
  gap: 6px;
}

.cwe-statline span {
  min-width: 0;
  padding: 7px 9px;
  font-size: 10.5px;
}

.cwe-duty-strip {
  padding-top: 8px;
  font-size: 10px;
}

.cwe-notice {
  flex: 0 0 auto;
  margin-bottom: 9px;
  padding: 8px 11px;
  border-radius: 11px;
  font-size: 10.5px;
}

.cwe-ledger-layout {
  grid-template-columns: minmax(0, 1fr) minmax(220px, 270px);
  gap: 9px;
}

.cwe-ledger-main,
.cwe-ledger-column,
.cwe-archive-column {
  display: grid;
  min-height: 0;
  grid-template-rows: auto minmax(0, 1fr);
}

.cwe-ledger-head {
  min-height: 45px;
  padding: 8px 12px;
}

.cwe-ledger-head h3,
.cwe-ledger-column > header h3,
.cwe-archive-column > header h3 {
  font-size: 14px;
}

.cwe-ledger-head small,
.cwe-ledger-column > header small,
.cwe-archive-column > header small {
  font-size: 9px;
}

.cwe-ledger-head button {
  padding: 5px 9px;
  font-size: 9.5px;
}

.cwe-event-list,
.cwe-stack,
.cwe-scroll-list {
  min-height: 0;
  overflow: auto;
  overscroll-behavior: contain;
}

.cwe-event-list {
  padding: 4px 7px 7px;
}

.cwe-event-row {
  grid-template-columns: 76px minmax(0, 1fr) minmax(155px, 190px);
  gap: 10px;
  margin: 2px 0;
  padding: 9px 8px;
  border-radius: 9px;
}

.cwe-event-when {
  padding-left: 23px;
}

.cwe-event-when i {
  width: 13px;
  height: 13px;
}

.cwe-event-when strong {
  font-size: 12px;
}

.cwe-event-when b,
.cwe-event-when span {
  font-size: 9.5px;
  line-height: 1.45;
}

.cwe-event-story header {
  gap: 7px;
}

.cwe-event-story h4 {
  font-family: var(--cwe-font-body);
  font-size: 13.5px;
  line-height: 1.35;
}

.cwe-event-story p {
  margin-top: 5px;
  font-size: 10.5px;
  line-height: 1.55;
  -webkit-line-clamp: 2;
}

.cwe-event-detail {
  gap: 4px;
}

.cwe-event-detail dt,
.cwe-event-detail dd {
  font-size: 9.5px;
  line-height: 1.45;
}

.cwe-margin-notes {
  grid-template-rows: repeat(2, minmax(0, 1fr));
  gap: 8px;
  overflow: hidden;
}

.cwe-margin-notes section {
  min-height: 0;
  padding: 11px 12px;
  border-radius: 13px;
}

.cwe-margin-notes header {
  padding-bottom: 7px;
  font-size: 9.5px;
}

.cwe-margin-notes h3 {
  margin: 9px 0 5px;
  font-family: var(--cwe-font-body);
  font-size: 13.5px;
  line-height: 1.4;
}

.cwe-margin-notes p {
  margin: 0;
  font-size: 10.5px;
  line-height: 1.55;
  -webkit-line-clamp: 3;
}

.cwe-margin-notes footer,
.cwe-hook-progress {
  font-size: 9px;
}

.cwe-section-head {
  min-height: 52px;
  flex: 0 0 auto;
  margin: 0 0 9px;
  padding: 2px 2px 9px;
}

.cwe-section-head p {
  font-size: 9px;
}

.cwe-section-head h2 {
  margin-top: 2px;
  font-family: var(--cwe-font-body);
  font-size: 18px;
  letter-spacing: 0.04em;
}

.cwe-section-head > span {
  font-size: 10px;
}

.cwe-events-ledger,
.cwe-archive-grid {
  gap: 9px;
  margin: 0;
  border: 0;
}

.cwe-events-ledger {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.cwe-archive-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.cwe-ledger-column,
.cwe-archive-column {
  padding: 0;
  border-right: 0;
  border-radius: 13px;
}

.cwe-ledger-column > header,
.cwe-archive-column > header {
  min-height: 46px;
  padding: 8px 11px;
}

.cwe-stack,
.cwe-scroll-list {
  max-height: none;
  padding: 1px;
}

.cwe-record,
.cwe-person,
.cwe-hook,
.cwe-fact {
  margin: 6px;
  padding: 10px 11px;
  border-radius: 10px;
}

.cwe-record h3,
.cwe-person h3,
.cwe-hook h3 {
  font-family: var(--cwe-font-body);
  font-size: 13.5px;
  line-height: 1.4;
  overflow-wrap: anywhere;
}

.cwe-record header small,
.cwe-record footer,
.cwe-person small,
.cwe-hook small,
.cwe-fact small {
  font-size: 9px;
}

.cwe-record > p,
.cwe-person p,
.cwe-hook > p,
.cwe-fact p {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 5px;
  font-size: 10.5px;
  line-height: 1.55;
  overflow-wrap: anywhere;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.cwe-record footer {
  margin-top: 7px;
}

.cwe-person {
  grid-template-columns: 32px minmax(0, 1fr);
  gap: 9px;
}

.cwe-avatar {
  width: 32px;
  height: 32px;
  font-size: 14px;
}

.cwe-empty {
  min-height: 110px;
  font-size: 10px;
}

.cwe-command-bar {
  min-height: 70px;
  padding: 6px 11px 5px;
}

.cwe-command-main {
  width: min(100%, 780px);
}

.cwe-command-bar .cwe-tabs button,
.cwe-command-main > button {
  min-height: 38px;
  padding-block: 0;
  font-size: 11.5px;
}

.cwe-command-main > .cwe-run-button {
  min-width: 132px;
}

.cwe-command-meta {
  width: min(100%, 780px);
}

.cwe-command-meta > p,
.cwe-command-meta > button.cwe-rebuild-link {
  font-size: 9.5px;
}

@media (max-width: 1120px) {
  .cwe-overview-lead {
    grid-template-columns: minmax(0, 1fr);
  }

  .cwe-overview-status {
    padding-top: 9px;
    padding-left: 0;
  }

  .cwe-ledger-layout {
    grid-template-columns: minmax(0, 1fr) minmax(210px, 250px);
  }
}
